# Cloudinary Configuration for KYC Document Uploads
# Get these values from your Cloudinary dashboard
# Cloud name: your-cloud-name
# Upload preset: available in Settings > Upload > Upload presets (unsigned)

VITE_CLOUDINARY_CLOUD_NAME=swiftrade-app
VITE_CLOUDINARY_UPLOAD_PRESET=swiftrade-app

# Backend API URL
VITE_API_BASE_URL=https://swift-jet-iota.vercel.app/api
